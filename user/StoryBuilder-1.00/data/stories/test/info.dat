title DnD Mechanics Test

set strength 16
set dexterity 12
set level 5

text Character Stats:
text Strength: <strength>, Dexterity: <dexterity>, Level: <level>.

text Step 1: Calculating strength modifier. Formula: (strength - 10) divided by 2.
call calc_modifier strength
set str_mod <lastreturn>
text Strength modifier is <str_mod>.

text Step 2: Calculating dexterity modifier.
call calc_modifier dexterity
set dex_mod <lastreturn>
text Dexterity modifier is <dex_mod>.

text Step 3: Rolling attack with strength modifier applied.
call roll_attack str_mod
set attack_roll <lastreturn>
text Attack roll result: <attack_roll>.

text Step 4: Calculating proficiency bonus for level <level>.
call calc_proficiency level
set prof_bonus <lastreturn>
text Proficiency bonus: <prof_bonus>.

text Step 5: Calculating final attack total.
call calc_attack_total attack_roll str_mod prof_bonus
text Final attack total: <lastreturn>.

text Globals unchanged. Strength: <strength>, Dexterity: <dexterity>, Level: <level>.
end

function calc_modifier stat
    var mod 0
    set mod <stat>
    sub mod 10
    div mod 2
    return <mod>
endfunction

function roll_attack str_mod
    var roll (1,20)
    var total 0
    set total <roll>
    add total <str_mod>
    return <total>
endfunction

function calc_proficiency level
    var bonus 2
    if <level> >= 5
        set bonus 3
    endif
    if <level> >= 9
        set bonus 4
    endif
    if <level> >= 13
        set bonus 5
    endif
    if <level> >= 17
        set bonus 6
    endif
    return <bonus>
endfunction

function calc_attack_total roll mod prof
    var total 0
    set total <roll>
    add total <mod>
    add total <prof>
    return <total>
endfunction
