title Password Generator
wait 500

text Welcome to password generator.

function main

array pass_types Numbers,Letters,Numbers+Letters,Symbols,Numbers+Symbols,Letters+Symbols,All

label loop_start

    menumode cancel:exit
    menu pass_types "Choose password type."
    set passtype <menu_choice>

    write passlen "Enter password length:"

    if passlen == ""
        goto loop_start
    endif

    var passlen_num <passlen>

    if passlen_num < 8
        text Password length must be at least 8 characters.
        goto loop_start
    elseif passlen_num > 256
        text Password length cannot exceed 256 characters.
        goto loop_start
    endif

    while true

        call genpassword

        menumode cancel:goto loop_start
        choice "What would you like to do?"
            "Generate again" continue
            "Change settings" goto loop_start
            "Exit generator" end
        endchoice

    endwhile

goto loop_start

return
endfunction


function genpassword

    if passtype == "Numbers"
        genpass num <passlen>
        return

    elseif passtype == "Letters"
        genpass let+LET <passlen>
        return

    elseif passtype == "Numbers+Letters"
        genpass num+let <passlen>
        return

    elseif passtype == "Symbols"
        genpass sim <passlen>
        return

    elseif passtype == "Numbers+Symbols"
        genpass num+sim <passlen>
        return

    elseif passtype == "Letters+Symbols"
        genpass let+sim <passlen>
        return

    elseif passtype == "All"
        genpass num+let+LET+sim <passlen>
        return
    endif

return
endfunction

call main
