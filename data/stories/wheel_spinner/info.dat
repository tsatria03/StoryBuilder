title Custom Wheel Spinner
wait 500

function main

text Welcome to the dynamic wheel spinner.

set haswheel 0

while true

    if haswheel == 0

        choice What would you like to do?
            "Create a new wheel" call createwheel
            "Exit spinner" break
        endchoice
    else
        choice What would you like to do?
            "Spin the wheel" call spinwheel
            "Create a new wheel" call createwheel
            "Exit spinner" break
        endchoice
    endif

endwhile

return
endfunction

function createwheel

    write wheelname Enter a name for your wheel.
    if wheelname == "" return

    write wheelitems Type wheel items separated by dashes. Example: pizza--burger--sushi
    if wheelitems == "" return

    array <wheelname> <wheelitems> --

    write spinspeed Enter starting spin speed. Example: 40
    if spinspeed == "" set spinspeed 40

    write slowdown Enter slowdown amount per tick. Example: 20
    if slowdown == "" set slowdown 20

    write spinticks Enter number of spin ticks. Example: 10
    if spinticks == "" set spinticks 10

    set haswheel 1

    return
endfunction

function spinwheel

    say spinning <wheelname>

    spin <wheelname> speed:<spinspeed> slowdown:<slowdown> ticks:<spinticks>

    return
endfunction

call main