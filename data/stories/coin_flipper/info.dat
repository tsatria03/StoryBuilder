title Coin Flipper
wait 500

function flipcoin
    say you flip a coin
    flip
    return
endfunction

function main

text Welcome to the coin flipper.

menumode cancel:exit

while true
    choice "What do you want to do?"
        "Flip a coin" call flipcoin
        "Exit coin flipper" break
    endchoice
endwhile

return
endfunction

call main
