if(cmd=="function")
{
    if(tokens.length()<1)
        return true;
    int depth=1;
    int scan=current_line+1;
    while(scan < int(lines.length()))
    {
        string line=lines[scan];
        string[] t=parse_story_tokens(line);
        if(t.length()>0)
        {
            string c=t[0].lower();
            if(c=="function")
                depth++;
            if(c=="endfunction")
            {
                depth--;
                if(depth==0)
                    break;
            }
        }
        scan++;
    }
    if(scan >= int(lines.length()))
        return true;
    current_line = scan;
    return true;
}
if(cmd=="endfunction")
{
    return true;
}
if(cmd=="break")
{
    if(break_stack.length()>0)
    {
        break_stack[break_stack.length()-1] = true;
    }
    return true;
}
if(cmd=="continue")
{
    if(continue_stack.length()>0)
    {
        continue_stack[continue_stack.length()-1] = true;
    }
    return true;
}
if(cmd=="for")
{
    if(tokens.length()<3)
        return true;
    string varname=tokens[0];
    int start=int(string_to_number(tokens[1]));
    int end=int(string_to_number(tokens[2]));
    int startline=current_line+1;
    int endline=startline;
    int depth=1;
    while(endline < lines.length())
    {
        string[] t=parse_story_tokens(lines[endline]);
        if(t.length()>0)
        {
            string c=t[0].lower();
            if(c=="for") depth++;
            else if(c=="endfor") depth--;
            if(depth==0)
                break;
        }
        endline++;
    }
    continue_stack.push_back(false);
    break_stack.push_back(false);
    int top = continue_stack.length()-1;
    for(int i=start;i<=end;i++)
    {
        vars.set(varname,string(i));
        int result = run_block(startline, endline);
if(result == 2)
{
    if(top >= 0) break_stack[top] = false;
    break;
}
if(result == 1)
{
    if(top >= 0) continue_stack[top] = false;
    continue;
}
    }
    if(continue_stack.length()>0) continue_stack.pop_back();
    if(break_stack.length()>0) break_stack.pop_back();
    current_line=endline;
    return true;
}
if(cmd=="foreach")
{
    if(tokens.length()<2)
        return true;
