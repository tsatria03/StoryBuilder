        return true;
    string prompt=tokens[0];
    setupmenu(false);
    m.intro_text=prompt;
    string[] commands;
    int scan=current_line+1;
    int endline=current_line;
    while(scan < int(lines.length()))
    {
        string line=lines[scan];
        string[] t=parse_story_tokens(line);
        if(t.length()==0)
        {
            scan++;
            continue;
        }
        string c=t[0].lower();
        if(c=="endmap")
        {
            endline=scan;
            break;
        }
        string label=t[0];
        t.remove_at(0);
        string action=string_join(t," ");
        m.add_item(label);
        commands.insert_last(action);
        scan++;
    }
    int result=m.run();
    current_line=endline;
    if(result>0 && result<=commands.length())
        return execute(commands[result-1]);
    return true;
}
if(cmd=="combat")
{
    last_menu_line = current_line;
if(tokens.length()<4)
return true;
string enemy=tokens[0];
int enemyhp=int(string_to_number(tokens[1]));
int mindmg=int(string_to_number(tokens[2]));
int maxdmg=int(string_to_number(tokens[3]));
combatwin=false;
dlgmessage("A "+enemy+" appears!");
while(enemyhp>0 && playerhp>0)
{
dlgmessage(enemy+" HP: "+string(enemyhp));
dlgmessage("Your HP: "+string(playerhp));
setupmenu(false);
m.intro_text="Choose your action";
m.add_item("Attack");
m.add_item("Use potion");
m.add_item("Run");
int choice=m.run();
if(choice==1)
{
int dmg=random(1,5);
dlgmessage("You deal "+string(dmg)+" damage.");
enemyhp-=dmg;
}
if(choice==2)
{
if(inv.exists("potion"))
{
inv.delete("potion");
int heal=5;
playerhp+=heal;
if(playerhp>playermaxhp)
playerhp=playermaxhp;
dlgmessage("You drink a potion.");
}
else
{
dlgmessage("You have no potion.");
}
}
if(choice==3)
{
dlgmessage("You escape.");
combatwin=false;
return true;
}
if(enemyhp<=0)
break;
int edmg=random(mindmg,maxdmg);
playerhp-=edmg;
dlgmessage(enemy+" hits you for "+string(edmg));
if(playerhp<=0)
break;
}
if(playerhp<=0)
{
dlgmessage("You were defeated.");
combatwin=false;
}
else
{
dlgmessage("You defeated the "+enemy);
combatwin=true;
}
return true;
}
if(cmd=="genpass")
{
    if(tokens.length()<2)
        return true;
    string types=tokens[0];
    int length=int(string_to_number(tokens[1]));
    if(length<=0)
        return true;
    string chars="";
    if(types.find("num")!=-1)
        chars+="0123456789";
    if(types.find("let")!=-1)
        chars+="abcdefghijklmnopqrstuvwxyz";
    if(types.find("LET")!=-1)
        chars+="ABCDEFGHIJKLMNOPQRSTUVWXYZ";
    if(types.find("sim")!=-1)
        chars+="!@#$%^&*()[]{};:'\"\\|,.<>?_/+=`~";
    if(chars=="")
        return true;
    string result="";
    for(int i=0;i<length;i++)
    {
        int r=random(0,chars.length()-1);
        result+=chars.substr(r,1);
    }
    vars.set("lastpass", result);
    dlgmessage("Your password is "+result);
    return true;
}
if(cmd=="genmap")
{
string[] locations={"forest", "town", "ruins", "cave", "lake", "tower", "village"};
worldmap.resize(0);
for(int i=0;i<5;i++)
{
int r=random(0,locations.length()-1);
worldmap.insert_last(locations[r]);
}
return true;
}
if(cmd=="worldmap")
{
    last_menu_line = current_line;
setupmenu(false);
m.intro_text="World Map";
for(uint i=0;i<worldmap.length();i++)
{
m.add_item(worldmap[i]);
}
m.add_item("Save game");
m.add_item("Exit story");
int r=m.run();
if(r<=worldmap.length())
{
return execute("goto "+worldmap[r-1]);
}
else if(r==worldmap.length()+1)
{
return execute("save");
}
else
{
return execute("exit");
}
return true;
}
if(cmd=="load")
{
file f;
if(!f.open("data/save.dat", "r"))
{
dlgmessage("No save file found.");
return true;
}
vars.clear();
inv.delete_all();
while(!f.eof)
{
string line=f.read();
string[] t=parse_story_tokens(line);
if(t.length()==0)
continue;
if(t[0]=="var")
{
string value = string_join(t, " ", 2);
vars.set(t[1], value);
}
if(t[0]=="item")
{
inv[t[1]]="1";
}
}
f.close();
dlgmessage("Story loaded.");
return true;
}
if(cmd=="save")
{
file f;
if(f.open("data/save.dat", "w"))
{
string[] keys=vars.vars.get_keys();
for(uint i=0;i<keys.length();i++)
{
string k=keys[i];
string v=vars.get(k);
f.write("var "+k+" "+v);
}
string[] items=inv.get_keys();
for(uint i=0;i<items.length();i++)
{
f.write("item "+items[i]);
}
f.close();
}
dlgmessage("Story saved.");
return true;
}
if(cmd=="checkpoint")
{
execute("save");
return true;
}
if(cmd=="if")
{
    if(tokens.length()<1)
        return true;
    string condition = string_join(tokens," ");
    condition = vars.replace_vars(condition);
    bool result = evaluate_condition(condition);
    if_result_stack.insert_last(result);
    if(result)
        return true;
    int depth=1;
    int scan=current_line+1;
    while(scan < int(lines.length()))
    {
        string[] t=parse_story_tokens(lines[scan]);
        if(t.length()>0)
        {
            string c=t[0].lower();
            if(c=="if")
                depth++;
            else if(c=="endif")
            {
                depth--;
                if(depth==0)
                {
                    current_line=scan;
                    skip_advance=true;
                    return true;
                }
            }
            else if(depth==1 && (c=="elseif" || c=="else"))
            {
                current_line=scan-1;
                return true;
            }
        }
        scan++;
    }
    return true;
}
if(cmd=="elseif")
{
    if(tokens.length()<1)
        return true;
    if(if_result_stack.length()==0)
        return true;
    bool already_matched = if_result_stack[if_result_stack.length()-1];
    if(already_matched)
    {
        int depth=1;
        int scan=current_line+1;
        while(scan < int(lines.length()))
        {
            string[] t=parse_story_tokens(lines[scan]);
            if(t.length()>0)
            {
                string c=t[0].lower();
                if(c=="if")
                    depth++;
                else if(c=="endif")
                {
                    depth--;
                    if(depth==0)
                    {
                        current_line=scan;
                        skip_advance=true;
                        return true;
                    }
                }
            }
            scan++;
        }
        return true;
    }
    string condition=string_join(tokens," ");
    condition = vars.replace_vars(condition);
    bool result = evaluate_condition(condition);
    if_result_stack[if_result_stack.length()-1] = result;
    if(result)
        return true;
    int depth=1;
    int scan=current_line+1;
    while(scan < int(lines.length()))
    {
        string[] t=parse_story_tokens(lines[scan]);
        if(t.length()>0)
        {
            string c=t[0].lower();
            if(c=="if")
                depth++;
            else if(c=="endif")
            {
                depth--;
                if(depth==0)
                {
                    current_line=scan;
                    skip_advance=true;
                    return true;
                }
            }
            else if(depth==1 && (c=="elseif" || c=="else"))
            {
                current_line=scan-1;
                return true;
            }
        }
        scan++;
    }
    return true;
}
if(cmd=="else")
{
    if(if_result_stack.length()==0)
        return true;
    bool already_matched = if_result_stack[if_result_stack.length()-1];
    if(already_matched)
    {
        int depth=1;
        int scan=current_line+1;
        while(scan < int(lines.length()))
        {
            string[] t=parse_story_tokens(lines[scan]);
            if(t.length()>0)
            {
                string c=t[0].lower();
                if(c=="if")
                    depth++;
                else if(c=="endif")
                {
                    depth--;
                    if(depth==0)
                    {
                        current_line=scan;
                        skip_advance=true;
                        return true;
                    }
                }
            }
            scan++;
        }
        return true;
    }
    if_result_stack[if_result_stack.length()-1] = true;
    return true;
}
if(cmd=="endif")
{
    if(if_result_stack.length()>0)
        if_result_stack.remove_last();
    return true;
}
if(cmd=="give")
{
if(tokens.length()<1)
return true;
string item=tokens[0];
inv[item]="1";
return true;
}
if(cmd=="recycle")
{
if(tokens.length()<1)
return true;
string item=tokens[0];
if(inv.exists(item))
inv.delete(item);
return true;
}
if(cmd=="inv")
{
string message="Inventory:";
string[] items=inv.get_keys();
if(items.length()==0)
{
message+="\r\n(empty)";
}
else
{
for(uint i=0;i<items.length();i++)
{
message+="\r\n"+items[i];
}
}
dlgmessage(message);
return true;
}
if(cmd=="invclear")
{
inv.delete_all();
return true;
}
if(cmd=="queststart")
{
if(tokens.length()<1)
return true;
string q=tokens[0];
quests[q]="1";
return true;
}
if(cmd=="questcomplete")
{
if(tokens.length()<1)
return true;
string q=tokens[0];
quests[q]="2";
return true;
}
if(cmd=="questfail")
{
if(tokens.length()<1)
return true;
string q=tokens[0];
quests[q]="3";
return true;
}
if(cmd=="questcheck")
{
if(tokens.length()<2)
return true;
string q=tokens[0];
tokens.remove_at(0);
string action=string_join(tokens," ");
if(quests.exists(q))
{
string state=string(quests[q]);
if(state=="1" || state=="2")
return execute(action);
}
return true;
}
if(cmd=="quests")
{
string msg="Quest Log:";
string[] keys=quests.get_keys();
bool empty=true;
for(uint i=0;i<keys.length();i++)
{
string q=keys[i];
string state=string(quests[q]);
if(state=="1")
{
msg+="\r\n"+q;
empty=false;
}
}
if(empty)
msg+="\r\n(no active quests)";
dlgmessage(msg);
return true;
}
if(cmd=="questclear")
{
quests.delete_all();
return true;
}
if(cmd=="title")
{
if(tokens.length()==0)
{
show_window(wintitle+", version "+version);
}
else
{
string newtitle=string_join(tokens," ");
show_window(newtitle);
}
return true;
}
if(cmd.starts_with("@"))
{
string folder=cmd.substr(1);
string newpath="data/stories/"+folder+"/info.dat";
parser.load(newpath);
return true;
}
if(cmd=="exit")
{
p.destroy_all();
muspool.destroy_all();
sourcepool.destroy_all();
show_window(wintitle+", version "+version);
return false;
}
if(cmd=="end")
{
p.destroy_all();
muspool.destroy_all();
sourcepool.destroy_all();
show_window(wintitle+", version "+version);
return false;
}
return true;
}
}
