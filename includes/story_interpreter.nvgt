}
if(cmd=="while")
{
    string key = string(current_line);
    int endline;
    if(!loopend.exists(key))
    {
        int scan=current_line+1;
        int depth=1;
        endline=current_line;
        while(scan < int(lines.length()))
        {
            string[] t=parse_story_tokens(lines[scan]);
            if(t.length()>0)
            {
                string c=t[0].lower();
                if(c=="while")
                    depth++;
                else if(c=="endwhile")
                {
                    depth--;
                    if(depth==0)
                    {
                        endline=scan;
                        break;
                    }
                }
            }
            scan++;
        }
        loopend[key] = string(endline);
        loopstart[string(endline)] = key;
    }
    endline = string_to_int(string(loopend[key]));
    string condition=string_join(tokens," ");
    condition = vars.replace_vars(condition, get_locals());
    bool result=false;
    if(condition.lower()=="true")
        result=true;
    else if(condition.lower()=="false")
        result=false;
    else
        result=evaluate_condition(condition);
    if(result)
    {
        string stack_key = "__while_active_" + key;
        if(!loopvars.exists(stack_key))
        {
            continue_stack.push_back(false);
            break_stack.push_back(false);
            loopvars[stack_key] = "1";
        }
    }
    else
    {
        string stack_key = "__while_active_" + key;
        if(loopvars.exists(stack_key))
        {
            loopvars.delete(stack_key);
            if(continue_stack.length()>0) continue_stack.remove_at(continue_stack.length()-1);
            if(break_stack.length()>0) break_stack.remove_at(break_stack.length()-1);
        }
        current_line=endline;
        skip_advance = true;
    }
    return true;
}
if(cmd=="endwhile")
{
    string key=string(current_line);
    if(!loopstart.exists(key))
        return true;
    int startline=string_to_int(string(loopstart[key]));
    string start_key = string(startline);
    string stack_key = "__while_active_" + start_key;
    string[] t=parse_story_tokens(lines[startline]);
    if(t.length()==0)
        return true;
    t.remove_at(0);
    string condition=string_join(t," ");
    condition = vars.replace_vars(condition, get_locals());
    bool result=false;
    if(condition.lower()=="true")
        result=true;
    else if(condition.lower()=="false")
        result=false;
    else
        result=evaluate_condition(condition);
    int top = continue_stack.length()-1;
    if(top >= 0)
    {
        if(break_stack[top])
        {
            break_stack[top] = false;
            if(loopvars.exists(stack_key))
                loopvars.delete(stack_key);
            continue_stack.remove_at(top);
            break_stack.remove_at(top);
            loopstart.delete(key);
            loopend.delete(string(startline));
            return true;
        }
        if(continue_stack[top])
        {
            continue_stack[top] = false;
            current_line = startline;
            skip_advance = true;
            return true;
        }
    }
    if(result)
    {
        current_line=startline;
        skip_advance = true;
    }
    else
    {
        if(loopvars.exists(stack_key))
            loopvars.delete(stack_key);
        if(continue_stack.length()>0) continue_stack.remove_at(continue_stack.length()-1);
        if(break_stack.length()>0) break_stack.remove_at(break_stack.length()-1);
        loopstart.delete(key);
        loopend.delete(string(startline));
    }
    return true;
}
if(cmd=="repeat")
{
    if(tokens.length()<1)
        return true;
    int count = int(string_to_number(tokens[0]));
    int startline = current_line + 1;
    int endline = startline;
    int depth = 1;
