if(cmd=="write")
{
    if(tokens.length()<1)
        return true;
    string varname = tokens[0];
    tokens.remove_at(0);
    string prompt = string_join(tokens, " ");
    prompt = vars.replace_vars(prompt, get_locals());
    if(write_mode_enabled)
        vd.set_disallowed_chars(write_chars, write_use_only, write_message);
    else
        vd.set_disallowed_chars("", false, "");
    string val = vd.input_box("", prompt);
    bool is_empty = (val == "");
    if(is_empty)
    {
        if(write_cancel == "exit")
        {
            vd.set_disallowed_chars("", false, "");
            return false;
        }
        if(write_cancel == "continue")
        {
            vd.set_disallowed_chars("", false, "");
            return true;
        }
        if(write_cancel == "loop")
        {
            while(val == "")
            {
                val = vd.input_box("", prompt);
            }
        }
    }
    vars.set(varname, val);
    vd.set_disallowed_chars("", false, "");
    return true;
}
if(cmd=="writemode")
{
    if(tokens.length() == 0)
    {
        write_mode_enabled = false;
        write_chars = "";
        write_use_only = false;
        write_message = "";
        write_cancel = "exit";
        return true;
    }
    dictionary args = parse_named_args(tokens);
    string[] clean_tokens;
    for(uint i=0;i<tokens.length();i++)
    {
        if(tokens[i].find(":")==-1)
            clean_tokens.insert_last(tokens[i]);
    }
    tokens = clean_tokens;
    string mode = get_arg_string(args, "cancel", write_cancel);
    mode = mode.lower();
    if(mode=="exit" || mode=="continue" || mode=="loop")
        write_cancel = mode;
    if(tokens.length() > 0)
    {
        write_mode_enabled = true;
        write_use_only = false;
        write_chars = "";
        write_message = "";
        string type = tokens[0];
        if(tokens.length() > 1)
        {
            string charmode = tokens[1].lower();
            if(charmode=="true" || charmode=="only" || charmode=="allow" || charmode=="on" || charmode=="1")
                write_use_only = true;
            else if(charmode=="false" || charmode=="block" || charmode=="deny" || charmode=="off" || charmode=="0")
                write_use_only = false;
        }
        if(tokens.length() > 2)
        {
            tokens.remove_at(0);
            tokens.remove_at(0);
            write_message = string_join(tokens, " ");
            write_message = vars.replace_vars(write_message, get_locals());
        }
        if(type.find("num")!=-1)
            write_chars += "0123456789";
        if(type.find("let")!=-1)
            write_chars += "abcdefghijklmnopqrstuvwxyz";
        if(type.find("LET")!=-1)
            write_chars += "ABCDEFGHIJKLMNOPQRSTUVWXYZ";
        if(type.find("sim")!=-1)
            write_chars += "!@#$%^&*()[]{};:'\"\\|,.<>?_/+=`~";
        if(type.find("spc")!=-1)
            write_chars += " ";
        if(type == "none")
        {
            write_mode_enabled = false;
        }
    }
    return true;
}
