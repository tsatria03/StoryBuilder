class story_interpreter
{
story_variables@ vars;
story_parser@ parser;

string write_cancel = "exit";
string write_chars = "";
bool write_use_only = false;
string write_message = "";
bool write_mode_enabled = false;

bool inline_return_mode = false;
string inline_return_value = "";
string last_return_value;
bool has_return_value = false;

int playerhp;
int playermaxhp;
int playerxp;
int playerlevel;
int lastroll;
int lastrollcount;
int lastrollsides;
int lastrollmodifier;

bool combatwin;
bool skip_advance = false;

string lastspin;
string lastflip;
string foreach_var;
string foreach_array;
string dlg_buffer = "";
string[] worldmap;

array<bool> continue_stack;
array<bool> break_stack;
array<bool> if_result_stack;
array<string> callstack;
array<int> while_stack;
array<dictionary> localstack;

dictionary loopvars;
dictionary loopstart;
dictionary loopend;
dictionary arrays;
dictionary journal;
dictionary inv;
dictionary quests;
dictionary functions;
dictionary question_answers;

story_interpreter(story_variables@ v, story_parser@ p)
{
@vars=v;
@parser=p;
}

bool evaluate_condition(string condition)
{
    string[] tokens = parse_story_tokens(condition);
    if(tokens.length() < 3)
        return false;
    bool first_condition = true;
    bool final_result = false;
    bool use_or = false;
    while(tokens.length() > 0)
    {
        bool result = false;
        string varname = tokens[0];
        tokens.remove_at(0);
        if(varname == "has")
        {
            if(tokens.length() < 1)
                return false;
            string item = tokens[0];
            tokens.remove_at(0);
            result = inv.exists(item);
        }
        else if(varname == "rand")
        {
            if(tokens.length() < 4)
                return false;
            int minv = int(string_to_number(tokens[0]));
            int maxv = int(string_to_number(tokens[1]));
            tokens.remove_at(0);
            tokens.remove_at(0);
            string op = tokens[0];
            tokens.remove_at(0);
            string value = tokens[0];
            tokens.remove_at(0);
            double a = random(minv, maxv);
            double b = string_to_number(value);
            if(op=="==") result=(a==b);
            else if(op=="!=") result=(a!=b);
            else if(op==">") result=(a>b);
            else if(op=="<") result=(a<b);
            else if(op==">=") result=(a>=b);
            else if(op=="<=") result=(a<=b);
        }
        else
        {
            if(tokens.length() < 2)
                return false;
            string op = tokens[0];
            tokens.remove_at(0);
            string value = tokens[0];
            tokens.remove_at(0);
            string varvalue = "";
            if(vars.exists(varname))
                varvalue = vars.get(varname);
            varvalue = strip_quotes(varvalue);
            value = strip_quotes(value);
            bool var_is_num = varvalue.is_digits();
            bool val_is_num = value.is_digits();
            if(var_is_num && val_is_num)
            {
                double a = string_to_number(varvalue);
                double b = string_to_number(value);
                if(op=="==") result=(a==b);
                else if(op=="!=") result=(a!=b);
                else if(op==">") result=(a>b);
                else if(op=="<") result=(a<b);
                else if(op==">=") result=(a>=b);
                else if(op=="<=") result=(a<=b);
            }
            else
            {
                if(op=="==") result=(varvalue == value);
                else if(op=="!=") result=(varvalue != value);
            }
        }
        if(first_condition)
        {
            final_result = result;
            first_condition = false;
        }
        else if(use_or)
        {
            final_result = final_result || result;
        }
        else
        {
            final_result = final_result && result;
        }
        if(tokens.length() > 0)
        {
            string logic = tokens[0].lower();
            if(logic=="and" || logic=="&&")
            {
                use_or = false;
                tokens.remove_at(0);
                continue;
            }
            if(logic=="or" || logic=="||")
            {
                use_or = true;
                tokens.remove_at(0);
                continue;
            }
        }
        break;
    }
    return final_result;
}

dictionary@ get_locals()
{
if(localstack.length()>0)
return @localstack[localstack.length()-1];
return null;
}
int run_block(int startline, int endline)
{
    int pc = startline;
    while(pc < endline)
    {
        if(trim(lines[pc]) == "")
        {
            pc++;
            continue;
        }
        int saved_line = current_line;
        bool saved_skip = skip_advance;
        current_line = pc;
        bool cont = execute(lines[pc]);
        int top = continue_stack.length()-1;
        if(top >= 0)
        {
            if(break_stack[top])
            {
                current_line = saved_line;
                skip_advance = saved_skip;
                return 2;
            }
            if(continue_stack[top])
            {
                current_line = saved_line;
                skip_advance = saved_skip;
                return 1;
            }
        }
        int nextpc;
        if(skip_advance)
            nextpc = current_line;
        else
            nextpc = pc + 1;
        current_line = saved_line;
        skip_advance = saved_skip;
        if(!cont)
            return 0;
        pc = nextpc;
    }
    return 0;
}

void flush_dialog()
{
if(dlg_buffer=="")
return;
dlgmessage(dlg_buffer);
dlg_buffer="";
}
bool execute(string line)
{
    if(in_block_comment)
    {
        int end = line.find("*/");
        if(end != -1)
        {
            line = line.substr(end + 2);
            in_block_comment = false;
        }
        else
        {
            return true;
        }
    }
    int block_start = line.find("/*");
    if(block_start != -1)
    {
        int block_end = line.find("*/", block_start + 2);
        if(block_end != -1)
        {
            line = line.substr(0, block_start) + line.substr(block_end + 2);
        }
        else
        {
            in_block_comment = true;
            line = line.substr(0, block_start);
        }
    }
    int cpos = line.find("//");
    if(cpos != -1)
        line = line.substr(0, cpos);
    cpos = line.find("#");
    if(cpos != -1)
        line = line.substr(0, cpos);
    cpos = line.find(";");
    if(cpos != -1)
        line = line.substr(0, cpos);
    line = vars.replace_vars(line, get_locals());
    line = process_random(line);
    line = trim(line);
    if(line == "")
        return true;
    string[] tokens = parse_story_tokens(line);
    if(tokens.length() == 0)
        return true;
    string cmd = tokens[0].lower();
    tokens.remove_at(0);
bool needs_flush=(cmd=="goto" || cmd=="gotoif" || cmd=="call" || cmd=="return" || cmd=="say" || cmd=="choice" || cmd=="menu" || cmd=="question" || cmd=="roll" || cmd=="flip" || cmd=="spin" || cmd=="genpass" || cmd=="map" || cmd=="worldmap" || cmd=="write" || cmd=="combat" || cmd=="cutplay" || cmd=="play" || cmd=="mus" || cmd=="amb" || cmd=="end" || cmd=="exit");
if(needs_flush)
flush_dialog();
if(cmd!="text")
flush_dialog();
if(cmd=="text")
{
string msg=string_join(tokens," ");
msg=vars.replace_vars(msg, get_locals());
msg=process_random(msg);
msg=process_math(msg);
if(dlg_buffer=="")
dlg_buffer=msg;
else
dlg_buffer+="\r\n"+msg;
return true;
}
if(cmd=="textsound")
{
if(tokens.length()==0)
{
dlgsound=true;
return true;
}
string state=tokens[0].lower();
if(state=="true" || state=="on" || state=="1")
dlgsound=true;
else if(state=="false" || state=="off" || state=="0")
dlgsound=false;
return true;
}
if(cmd=="say")
{
string msg=string_join(tokens," ");
msg=vars.replace_vars(msg, get_locals());
msg=process_random(msg);
msg=process_math(msg);
speak(msg);
return true;
}
if(cmd=="return")
{
    string value = "";
    if(tokens.length() > 0)
    {
        value = string_join(tokens, " ");
        value = vars.replace_vars(value, get_locals());
        if(value.starts_with("call "))
        {
            string[] ctokens = parse_story_tokens(value);
            if(ctokens.length() >= 2)
            {
                string fname = ctokens[1];
                if(functions.exists(fname))
                {
                    int target = string_to_int(string(functions[fname]));
                    if(target >= 0 && target < int(lines.length()))
                    {
                        dictionary locals;
                        localstack.insert_last(locals);
                        string[] ftokens = parse_story_tokens(lines[target]);
                        uint maxargs = ctokens.length() > 2 ? ctokens.length()-2 : 0;
                        uint maxparams = ftokens.length() > 2 ? ftokens.length()-2 : 0;
                        uint count = maxargs < maxparams ? maxargs : maxparams;
                        for(uint i=0; i<count; i++)
                        {
                            localstack[localstack.length()-1].set(ftokens[i+2], ctokens[i+2]);
                        }
                        int endline = find_endfunction(target);
                        inline_return_mode = true;
                        inline_return_value = "";
                        if(endline > target)
                            run_block(target + 1, endline);
                        inline_return_mode = false;
                        value = inline_return_value;
                        if(localstack.length() > 0)
                            localstack.remove_last();
                    }
                    else
                    {
                        value = "";
                    }
                }
                else
                {
                    value = "";
                }
            }
        }
        else
        {
            value = eval_expr(value);
        }
    }
    if(inline_return_mode)
    {
        inline_return_value = value;
        return false;
    }
    if(callstack.length()==0)
        return true;
    vars.set("lastreturn", value);
    if(localstack.length() > 0)
        localstack.remove_last();
    current_line = string_to_int(callstack[callstack.length()-1]);
    callstack.remove_last();
    skip_advance = true;
    return true;
}
if(cmd=="call")
{
    if(tokens.length()<1)
        return true;
    string fname = tokens[0];
    tokens.remove_at(0);
    if(!functions.exists(fname))
        return true;
    dictionary locals;
    localstack.insert_last(locals);
    callstack.insert_last(string(current_line + 1));
    int target = string_to_int(string(functions[fname]));
    if(target < 0 || target >= int(lines.length()))
        return true;
    string[] ftokens = parse_story_tokens(lines[target]);
    for(uint i=0;i<tokens.length();i++)
    {
        if(i+2 < ftokens.length())
        {
            string argname = ftokens[i+2];
            localstack[localstack.length()-1].set(argname, tokens[i]);
        }
    }
    current_line = target + 1;
    skip_advance = true;
    return true;
}
if(cmd=="length")
{
    if(tokens.length()<2)
        return true;
    string target=tokens[0];
    string resultvar=tokens[1];
    string[] arr;
    if(arrays.get(target, arr))
    {
        vars.set(resultvar, string(arr.length()));
        return true;
    }
    if(vars.exists(target))
    {
        string val=vars.get(target);
        vars.set(resultvar, string(val.length()));
        return true;
    }
    vars.set(resultvar, string(target.length()));
    return true;
}
if(cmd=="menu")
{
    last_menu_line = current_line;
    if(tokens.length()<1)
        return true;
    string arrname=tokens[0];
    tokens.remove_at(0);
    string prompt="Choose an option.";
    if(tokens.length()>0)
        prompt=string_join(tokens," ");
    string[] arr;
    if(!arrays.get(arrname, arr))
        return true;
    setupmenu(false);
    for(uint i=0;i<arr.length();i++)
        m.add_item(arr[i]);
    m.intro_text=prompt;
    int result=m.run();
    if(result<=0 || result>arr.length())
    {
        vars.set("menuindex","0");
        vars.set("menu_choice","");
        return true;
    }
    vars.set("menuindex",string(result));
    string choice = arr[result-1];
    vars.set("menu_choice", "\"" + choice + "\"");
    return true;
}
if(cmd=="menuindex")
{
    vars.set("menuindex",string(menuindex));
    return true;
}
if(cmd=="menucom")
{
    if(tokens.length()<1)
        return true;
    string arrname=tokens[0];
    string[] arr;
    if(!arrays.get(arrname, arr))
        return true;
    if(!vars.exists("menuindex"))
        return true;
    int idx=string_to_int(vars.get("menuindex"));
    if(idx<=0 || idx>int(arr.length()))
        return true;
    string cmdline=arr[idx-1];
    string[] cmds=string_split(cmdline,";",true);
    for(uint i=0;i<cmds.length();i++)
    {
        string c=cmds[i];
        if(c!="")
            execute(c);
    }
    return true;
}
if(cmd=="push")
{
    if(tokens.length()<2)
        return true;
    string arrname=tokens[0];
    tokens.remove_at(0);
    string value=string_join(tokens," ");
    string[] arr;
    arrays.get(arrname, arr);
    arr.insert_last(value);
    arrays.set(arrname, arr);
    return true;
}
if(cmd=="pop")
{
    if(tokens.length()<1)
        return true;
    string arrname=tokens[0];
    string[] arr;
    if(!arrays.get(arrname, arr))
        return true;
    if(arr.length()==0)
        return true;
    arr.remove_at(arr.length()-1);
    arrays.set(arrname, arr);
    return true;
}
if(cmd=="shuffle")
{
    if(tokens.length()<1)
        return true;
    string arrname=tokens[0];
    string[] arr;
    if(!arrays.get(arrname, arr))
        return true;
    for(uint i=0;i<arr.length();i++)
    {
        int j=random(0, arr.length()-1);
        string tmp=arr[i];
        arr[i]=arr[j];
        arr[j]=tmp;
    }
    arrays.set(arrname, arr);
    return true;
}
if(cmd=="pick")
{
    if(tokens.length()<2)
        return true;
    string arrname=tokens[0];
    string varname=tokens[1];
    string[] arr;
    if(!arrays.get(arrname, arr))
        return true;
    if(arr.length()==0)
        return true;
    int r=random(0, arr.length()-1);
    vars.set(varname, arr[r]);
    return true;
}
if(cmd=="remove")
{
    if(tokens.length()<2)
        return true;
    string arrname=tokens[0];
    tokens.remove_at(0);
    string value=string_join(tokens," ");
    string[] arr;
    if(!arrays.get(arrname, arr))
        return true;
    for(int i=int(arr.length())-1;i>=0;i--)
    {
        if(arr[i]==value)
            arr.remove_at(i);
    }
    arrays.set(arrname, arr);
    return true;
}
if(cmd=="remove_first")
{
    if(tokens.length()<2)
        return true;
    string arrname=tokens[0];
    tokens.remove_at(0);
    string value=string_join(tokens," ");
    string[] arr;
    if(!arrays.get(arrname, arr))
        return true;
    for(uint i=0;i<arr.length();i++)
    {
        if(arr[i]==value)
        {
            arr.remove_at(i);
            break;
        }
    }
    arrays.set(arrname, arr);
    return true;
}
if(cmd=="remove_last")
{
    if(tokens.length()<2)
        return true;
    string arrname=tokens[0];
    tokens.remove_at(0);
    string value=string_join(tokens," ");
    string[] arr;
    if(!arrays.get(arrname, arr))
        return true;
    for(int i=int(arr.length())-1;i>=0;i--)
    {
        if(arr[i]==value)
        {
            arr.remove_at(i);
            break;
        }
    }
    arrays.set(arrname, arr);
    return true;
}
if(cmd=="join")
{
    if(tokens.length()<3)
        return true;
    string arrname=tokens[0];
    string separator=tokens[1];
    string resultvar=tokens[2];
    string[] arr;
    if(!arrays.get(arrname, arr))
        return true;
    string result="";
    for(uint i=0;i<arr.length();i++)
    {
        if(i>0)
            result+=separator;
        result+=arr[i];
    }
    vars.set(resultvar, result);
    return true;
}
if(cmd=="filter")
{
    if(tokens.length()<3)
        return true;
    string source=tokens[0];
    string value=tokens[1];
    string result=tokens[2];
    string[] src;
    if(!arrays.get(source, src))
        return true;
    string[] result_arr;
    for(uint i=0;i<src.length();i++)
    {
        if(src[i].find(value)!=-1)
            result_arr.insert_last(src[i]);
    }
    arrays.set(result, result_arr);
    return true;
}
if(cmd=="sort")
{
    if(tokens.length()<1)
        return true;
    string arrname=tokens[0];
    string mode="alpha";
    if(tokens.length()>1)
        mode=tokens[1].lower();
    string[] arr;
    if(!arrays.get(arrname, arr))
        return true;
    if(mode=="natural")
        arr.sort(natural_number_sort);
    else
        arr.sort_ascending();
    arrays.set(arrname, arr);
    return true;
}
if(cmd=="range")
{
    if(tokens.length()<3)
        return true;
    string arrname=tokens[0];
    int start=int(string_to_number(tokens[1]));
    int end=int(string_to_number(tokens[2]));
    int step=1;
    if(tokens.length()>3)
        step=int(string_to_number(tokens[3]));
    if(step==0)
        step=1;
    string[] arr;
    if(start<=end)
    {
        for(int i=start;i<=end;i+=step)
            arr.insert_last(string(i));
    }
    else
    {
        for(int i=start;i>=end;i-=step)
            arr.insert_last(string(i));
    }
    arrays.set(arrname, arr);
    return true;
}
if(cmd=="wait")
{
    if(tokens.length()>0)
    {
        string expr = string_join(tokens, " ");
        expr = eval_expr(expr);
        int ms = int(string_to_number(expr));
        if(ms < 0)
            ms = 0;
        wait(ms);
    }
    return true;
}
if(cmd=="array")
{
    if(tokens.length()<2)
        return true;
    string name=tokens[0];
    tokens.remove_at(0);
    string delimiter="";
    if(tokens.length()>1)
    {
        delimiter=tokens[tokens.length()-1];
        tokens.remove_last();
    }
    string data=string_join(tokens," ");
    string[] items;
    if(delimiter!="")
    {
        items=string_split(data,delimiter,true);
    }
    else
    {
        if(data.find(",")!=-1)
            items=string_split(data,",",true);
        else
            items=string_split(data," ",true);
    }
    for(uint i=0;i<items.length();i++)
        items[i]=trim(items[i]);
    arrays.set(name,items);
    return true;
}
if(cmd=="randitem")
{
    if(tokens.length()<2)
        return true;
    string arrname=tokens[0];
    string varname=tokens[1];
    if(!arrays.exists(arrname))
        return true;
    string[] arr;
    if(!arrays.get(arrname, arr))
        return true;
    if(arr.length()==0)
        return true;
    int i=random(0,arr.length()-1);
    vars.set(varname,arr[i]);
    return true;
}
if(cmd=="flip")
{
string result="";
dlgplay(get_sound("misc/*coinflip*"),false);
int r=random(1,2);
if(r==1)
result="Heads";
else
result="Tails";
vars.set("lastflip", result);
dlgmessage("It lands on "+result+".");
return true;
}
if(cmd=="roll")
{
if(tokens.length()<1)
return true;
string expr=tokens[0];
int dice=1;
int sides=6;
int modifier=0;
int dpos=expr.find("d");
if(dpos!=-1)
{
dice=int(string_to_number(expr.substr(0,dpos)));
}
string remain=expr.substr(dpos+1);
int pluspos=remain.find("+");
int minuspos=remain.find("-");
if(pluspos!=-1)
{
sides=int(string_to_number(remain.substr(0,pluspos)));
modifier=int(string_to_number(remain.substr(pluspos+1)));
}
else if(minuspos!=-1)
{
sides=int(string_to_number(remain.substr(0,minuspos)));
modifier=-int(string_to_number(remain.substr(minuspos+1)));
}
else
{
sides=int(string_to_number(remain));
}
if(dice<1) dice=1;
if(sides<1) sides=1;
dlgplay(get_sound("misc/*diceroll*"),false);
dlgplay(get_sound("misc/*diceland*"),false);
int total=0;
string results="The dice show: ";
for(int i=0;i<dice;i++)
{
int r=random(1,sides);
total+=r;
results+=string(r);
if(i<dice-1)
results+=", ";
}
total+=modifier;
string modtext="";
if(modifier>0)
modtext="plus "+string(modifier);
else if(modifier<0)
modtext="minus "+string(abs(modifier));
else
modtext="zero";
results+=", with a modifier of "+modtext;
results+=", for a total score of "+string(total);
lastroll=total;
lastrollcount=dice;
lastrollsides=sides;
lastrollmodifier=modifier;
vars.set("lastroll",string(lastroll));
vars.set("lastrollcount",string(lastrollcount));
vars.set("lastrollsides",string(lastrollsides));
vars.set("lastrollmodifier",string(lastrollmodifier));
dlgmessage(results);
return true;
}
if(cmd=="spin")
{
if(tokens.length()<1)
return true;
string arrname=tokens[0];
string[] wheel;
if(!arrays.get(arrname, wheel))
return true;
if(wheel.length()==0)
return true;
dictionary args=parse_named_args(tokens,1);
int delay=int(get_arg_number(args,"speed",40));
int slowdown=int(get_arg_number(args,"slowdown",20));
int ticks=int(get_arg_number(args,"ticks",10));
while(ticks>0)
{
    p.play_stationary(get_sound("misc/*wheelspin*"),false);
    wait(delay);
    delay+=slowdown;
    ticks--;
    if(key_repeating(KEY_ESCAPE))
        break;
}
p.play_stationary(get_sound("misc/*wheelding*"),false);
int r=random(0,wheel.length()-1);
string result=wheel[r];
vars.set("lastspin",result);
dlgmessage("The wheel landed on "+result+".");
return true;
}
if(cmd=="label")
{
return true;
}
if(cmd=="goto")
{
    if(tokens.length()<1)
        return true;
    string labelname=tokens[0];
    int target=-1;
    for(int i=0;i<int(lines.length());i++)
    {
        string[] t=parse_story_tokens(lines[i]);
        if(t.length()>1 && t[0].lower()=="label" && t[1]==labelname)
        {
            target=i;
            break;
        }
    }
    if(target!=-1)
        current_line = target-1;
skip_advance = true;
return true;
}
if(cmd=="gotoif")
{
    if(tokens.length()<3)
        return true;
    string varname=tokens[0];
    string value=tokens[1];
    string labelname=tokens[2];
    if(vars.exists(varname))
    {
        string v = vars.get(varname);
        if(v==value)
        {
            int target=-1;
            for(int i=0;i<int(lines.length());i++)
            {
                string[] t=parse_story_tokens(lines[i]);
                if(t.length()>1 && t[0].lower()=="label" && t[1]==labelname)
                {
                    target=i;
                    break;
                }
            }
            if(target!=-1)
                current_line=target-1;
                        skip_advance = true;
}
    }
    return true;
}
