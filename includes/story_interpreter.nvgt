                depth--;
            if(depth == 0)
                break;
        }
        endline++;
    }
    continue_stack.push_back(false);
    break_stack.push_back(false);
    int top = continue_stack.length()-1;
    for(int r = 0; r < count; r++)
    {
        int result = run_block(startline, endline);
if(result == 2)
{
    if(top >= 0) break_stack[top] = false;
    break;
}
if(result == 1)
{
    if(top >= 0) continue_stack[top] = false;
    continue;
}
    }
    if(continue_stack.length()>0) continue_stack.pop_back();
    if(break_stack.length()>0) break_stack.pop_back();
    current_line = endline;
    return true;
